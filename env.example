# Eli environment example
# Copy to `.env` and fill values.

# ---------------------------------------------------------------------------
# Agent runtime
# ---------------------------------------------------------------------------
# Republic model format: provider:model_id
# Default in code is `openrouter:qwen/qwen3-coder-next`.
# ELI_MODEL=openrouter:qwen/qwen3-coder-next
# ELI_MAX_STEPS=50
# ELI_MAX_TOKENS=1024
# ELI_MODEL_TIMEOUT_SECONDS=300
# ELI_HOME=~/.eli

# ---------------------------------------------------------------------------
# API keys (choose one)
# ---------------------------------------------------------------------------
# `AgentSettings` reads `ELI_API_KEY` and `ELI_API_BASE` directly.
# Provider-specific keys such as `OPENROUTER_API_KEY` may still be used by
# the underlying SDK/provider setup, but are not read by Eli settings itself.

# Preferred explicit key
# ELI_API_KEY=sk-...

# Optional custom API base
# ELI_API_BASE=https://openrouter.ai/api/v1

# Optional upstream API shape:
# - completion: legacy completion-style requests (default)
# - responses: OpenAI Responses API
# - messages: chat-completions-style messages API
# ELI_API_FORMAT=completion

# ---------------------------------------------------------------------------
# Channel manager
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all`.
# `all` excludes the builtin `cli` channel.
# ELI_ENABLED_CHANNELS=all
# ELI_DEBOUNCE_SECONDS=1.0
# ELI_MAX_WAIT_SECONDS=10.0
# ELI_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# Telegram channel (optional)
# ---------------------------------------------------------------------------
# ELI_TELEGRAM_TOKEN=123456:telegram-bot-token
# Comma-separated values:
# ELI_TELEGRAM_ALLOW_USERS=123456789,my_username
# ELI_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# ELI_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Example minimal OpenRouter setup
# ---------------------------------------------------------------------------
# ELI_MODEL=openrouter:qwen/qwen3-coder-next
# ELI_API_KEY=sk-or-...
