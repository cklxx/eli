{
  "name": "eli-sidecar",
  "version": "0.2.0",
  "description": "OpenClaw plugin bridge for eli — load any OpenClaw channel plugin over HTTP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "start.cjs"
  ],
  "bin": {
    "eli-sidecar": "start.cjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "node scripts/patch-openclaw-exports.cjs",
    "prepublishOnly": "npm run build",
    "start": "node start.cjs",
    "dev": "node --watch start.cjs",
    "test": "bun test"
  },
  "keywords": [
    "eli",
    "openclaw",
    "feishu",
    "lark",
    "discord",
    "sidecar",
    "agent",
    "channel"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tencent-weixin/openclaw-weixin": "2.1.8",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "jiti": "^2.6.1",
    "openclaw": "2026.4.15"
  },
  "peerDependencies": {
    "@larksuite/openclaw-lark": ">=2026.0.0",
    "@openclaw/discord": ">=2026.0.0"
  },
  "peerDependenciesMeta": {
    "@larksuite/openclaw-lark": {
      "optional": true
    },
    "@openclaw/discord": {
      "optional": true
    }
  },
  "devDependencies": {
    "@larksuite/openclaw-lark": "^2026.3.25",
    "@openclaw/discord": "^2026.3.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
