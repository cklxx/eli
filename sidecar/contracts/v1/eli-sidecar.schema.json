{
  "$id": "https://eliagent.github.io/contracts/eli-sidecar-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_version": "eli.sidecar.v1",
  "definitions": {
    "channel_message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "MessageKind": {
          "description": "Semantic kind of a channel message.",
          "enum": [
            "normal",
            "error",
            "command",
            "join"
          ],
          "type": "string"
        },
        "SidecarContext": {
          "additionalProperties": true,
          "properties": {
            "_eli_cleanup_only": {
              "type": "boolean"
            },
            "account_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "channel_target": {
              "type": [
                "string",
                "null"
              ]
            },
            "chat_type": {
              "type": [
                "string",
                "null"
              ]
            },
            "group_label": {
              "type": [
                "string",
                "null"
              ]
            },
            "outbound_media": {
              "items": {
                "$ref": "#/definitions/SidecarMediaPayload"
              },
              "type": "array"
            },
            "reply_to_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "sender_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "sender_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "source_channel": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "type": "object"
        },
        "SidecarMediaPayload": {
          "properties": {
            "data_base64": {
              "type": [
                "string",
                "null"
              ]
            },
            "filename": {
              "type": [
                "string",
                "null"
              ]
            },
            "media_type": {
              "type": "string"
            },
            "mime_type": {
              "type": "string"
            },
            "path": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "media_type"
          ],
          "type": "object"
        }
      },
      "properties": {
        "channel": {
          "type": "string"
        },
        "chat_id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "context": {
          "allOf": [
            {
              "$ref": "#/definitions/SidecarContext"
            }
          ],
          "default": {}
        },
        "contract_version": {
          "default": "eli.sidecar.v1",
          "type": "string"
        },
        "is_active": {
          "default": false,
          "type": "boolean"
        },
        "kind": {
          "allOf": [
            {
              "$ref": "#/definitions/MessageKind"
            }
          ],
          "default": "normal"
        },
        "media": {
          "items": {
            "$ref": "#/definitions/SidecarMediaPayload"
          },
          "type": "array"
        },
        "output_channel": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        }
      },
      "required": [
        "channel",
        "chat_id",
        "content",
        "output_channel",
        "session_id"
      ],
      "title": "SidecarChannelMessage",
      "type": "object"
    },
    "notice_request": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "contract_version": {
          "default": "eli.sidecar.v1",
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "session_id",
        "text"
      ],
      "title": "SidecarNoticeRequest",
      "type": "object"
    },
    "tool_request": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "properties": {
        "contract_version": {
          "default": "eli.sidecar.v1",
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "params": {
          "default": null
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "title": "SidecarToolRequest",
      "type": "object"
    }
  },
  "title": "Eli Sidecar Contract"
}
